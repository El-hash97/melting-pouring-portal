generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id          String      @id @default(cuid())
  name        String
  description String
  logoIcon    String      @default("flame")
  accessLink  String
  status      AppStatus   @default(ACTIVE)
  category    String      @default("General")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  feedbacks   Feedback[]

  @@map("applications")
}

model Feedback {
  id          String      @id @default(cuid())
  appId       String
  app         Application @relation(fields: [appId], references: [id], onDelete: Cascade)
  rating      Int
  message     String
  isResolved  Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@map("feedbacks")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("users")
}

enum AppStatus {
  ACTIVE
  MAINTENANCE
}
